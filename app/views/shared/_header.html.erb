<header class="py-1">
  <div class="container mx-auto flex justify-between items-center px-4 md:px-8 lg:px-12 w-full text-first">
    <%= link_to "archimate", user_signed_in? ? authenticated_root_path : root_path, class: "text-xl mr-12" %>
    <% if user_signed_in? %>
      <div class="hidden lg:flex items-center gap-6">
        <%= link_to "サービス紹介", top_path %>
        <%= link_to "アカウント", edit_user_registration_path %>
        <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: "ログアウトしますか？" } %>
      </div>
      <div class="lg:hidden flex items-center gap-4">
        <%= link_to "Info", top_path %>
        <%= link_to "Edit", edit_user_registration_path %>
        <%= link_to "Out", destroy_user_session_path, data: { turbo_method: :delete } %>
      </div>
    <% else %>
      <div class="hidden lg:flex items-center gap-6">
        <%= link_to "サービス紹介", top_path %>
        <%= link_to "ログイン", new_user_session_path %>
        <%= link_to "会員登録", new_user_registration_path, class: "px-4 py-2 bg-second rounded-full hover:scale-105 transition" %>
      </div>
      <div class="lg:hidden flex items-center gap-4">
        <%= link_to "Info", top_path %>
        <%= link_to "Login", new_user_session_path %>
      </div>
    <% end %>
  </div>
</header>
