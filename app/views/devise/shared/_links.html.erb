<div class="mt-8 space-y-3 text-center text-sm text-neutral-600">
  <% if controller_name != "sessions" %>
    <p><%= link_to t("devise.shared.links.sign_in"), new_session_path(resource_name), class: "hover:text-first" %></p>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <p><%= link_to t("devise.shared.links.sign_up"), new_registration_path(resource_name), class: "hover:text-first" %></p>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <p><%= link_to t("devise.shared.links.forgot_your_password"), new_password_path(resource_name), class: "hover:text-first" %></p>
  <% end %>
</div>
