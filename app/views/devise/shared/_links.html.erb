<div class="mt-8 space-y-3 text-center text-sm text-neutral-600">
  <% if controller_name != "sessions" %>
    <p><%= link_to "ログインはこちらから", new_session_path(resource_name), class: "hover:text-first" %></p>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <p><%= link_to "新規会員登録", new_registration_path(resource_name), class: "hover:text-first" %></p>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <p><%= link_to "パスワードをお忘れですか？", new_password_path(resource_name), class: "hover:text-first" %></p>
  <% end %>

  <% if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <p><%= link_to "確認メールが届かない場合", new_confirmation_path(resource_name), class: "hover:text-first" %></p>
  <% end %>

  <% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <p><%= link_to "ロック解除メールが届かない場合", new_unlock_path(resource_name), class: "hover:text-first" %></p>
  <% end %>
</div>
