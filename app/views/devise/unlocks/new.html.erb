<% content_for :title, "Unlock instructions | archimate" %>
<h2 class="px-16 pt-16 text-center text-base md:text-xl">ロック解除メールを再送する</h2>
<section>
  <div class="p-12 md:p-24">
    <div class="max-w-md mx-auto">
      <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-2">
          <%= f.label :email, "メールアドレス", class: "block text-md text-neutral-600" %>
          <%= f.email_field :email, autocomplete: "email", class: "block w-full px-5 py-3 text-neutral-600 placeholder-gray-300 transition duration-200 border border-transparent rounded-full bg-gray-50 focus:border-transparent focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-300", required: true %>
        </div>

        <%= f.submit "ロック解除メールを再送する", class: "mt-16 py-4 w-full bg-first text-white transition duration-200 hover:scale-105 rounded-full cursor-pointer" %>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
