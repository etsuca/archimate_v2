<% content_for :title, "Log in | archimate" %>
<h2 class="px-16 pt-16 text-center text-base md:text-xl">ログイン</h2>
<section>
  <div class="p-12 md:p-24">
    <div class="max-w-md mx-auto">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-2">
          <%= f.label :email, "メールアドレス", class: "block text-md text-neutral-600" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "Email", class: "block w-full px-5 py-3 text-neutral-600 placeholder-gray-300 transition duration-200 border border-transparent rounded-full bg-gray-50 focus:border-transparent focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-300", required: true %>
        </div>

        <div class="space-y-2">
          <%= f.label :password, "パスワード", class: "mt-8 block text-md text-neutral-600" %>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "Password", class: "block w-full px-5 py-3 text-neutral-600 placeholder-gray-300 transition duration-200 border border-transparent rounded-full bg-gray-50 focus:border-transparent focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-300", required: true %>
          <div class="pt-2 text-end">
            <%= link_to "パスワードをお忘れですか？", new_password_path(resource_name), class: "block text-xs sm:text-sm text-neutral-600 hover:text-first" %>
          </div>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="mt-6 flex items-center gap-2 text-sm text-neutral-600">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, "ログイン状態を保持する" %>
          </div>
        <% end %>

        <%= f.submit "ログイン", class: "mt-16 py-4 w-full bg-first text-white transition duration-200 hover:scale-105 rounded-full cursor-pointer" %>
      <% end %>

      <div class="relative mb-4 mt-12">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 text-neutral-600 bg-third">はじめてご利用の方</span>
        </div>
      </div>

      <div class="mb-24">
        <%= link_to "新規会員登録", new_registration_path(resource_name), class: "block w-full py-4 text-center bg-first text-white transition duration-200 hover:scale-105 rounded-full cursor-pointer" %>
      </div>
    </div>
  </div>
</section>
