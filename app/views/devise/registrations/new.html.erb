<% content_for :title, "Sign up | archimate" %>
<h2 class="px-16 pt-16 text-center text-base md:text-xl">新規会員登録</h2>
<section>
  <div class="p-12 md:p-24">
    <div class="max-w-md mx-auto">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-2">
          <%= f.label :email, "メールアドレス", class: "mt-8 block text-md text-neutral-600" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "Email", class: "block w-full px-5 py-3 text-neutral-600 placeholder-gray-300 transition duration-200 border border-transparent rounded-full bg-gray-50 focus:border-transparent focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-300", required: true %>
        </div>

        <div class="space-y-2 mt-8 text-md text-neutral-600">
          <%= f.label :password, "パスワード" %>
          <% if @minimum_password_length %>
            <span>(<%= @minimum_password_length %>文字以上)</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Password", class: "block w-full px-5 py-3 text-neutral-600 placeholder-gray-300 transition duration-200 border border-transparent rounded-full bg-gray-50 focus:border-transparent focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-300", required: true %>
        </div>

        <div>
          <%= f.label :password_confirmation, "パスワード確認", class: "mt-8 block text-md text-neutral-600" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Password Confirmation", class: "block w-full px-5 py-3 text-neutral-600 placeholder-gray-300 transition duration-200 border border-transparent rounded-full bg-gray-50 focus:border-transparent focus:ring-white focus:ring-offset-2 focus:ring-offset-gray-300", required: true %>
        </div>

        <%= f.submit "新規会員登録", class: "mt-16 py-4 w-full bg-first text-white transition duration-200 hover:scale-105 rounded-full cursor-pointer" %>
      <% end %>

      <div class="relative mt-12 mb-4">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 text-neutral-600 bg-third">会員登録がお済みの方</span>
        </div>
      </div>

      <div class="mb-24">
        <%= link_to "ログインはこちらから", new_user_session_path, class: "block w-full py-4 text-center text-white bg-first transition duration-200 hover:scale-105 rounded-full cursor-pointer" %>
      </div>
    </div>
  </div>
</section>
